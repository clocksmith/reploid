{
  "name": "f16-batched",
  "description": "F16 activations with multi-token decode batching for lower submit/readback overhead.",
  "extends": "compute/f16-activations",
  "runtime": {
    "inference": {
      "batching": {
        "batchSize": 16,
        "stopCheckMode": "batch",
        "readbackInterval": 8,
        "ringTokens": 8,
        "ringStop": 8,
        "ringStaging": 8
      }
    }
  }
}
