{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "reploid",
      "public": "self",
      "ignore": [
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/zero",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/x",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.js",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.css",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.json",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/styles/rd-tokens.css",
          "destination": "/styles/rd.css"
        },
        {
          "source": "/styles/rd-primitives.css",
          "destination": "/styles/rd.css"
        },
        {
          "source": "/styles/rd-components.css",
          "destination": "/styles/rd.css"
        },
        {
          "source": "/rd-tokens.css",
          "destination": "/styles/rd.css"
        },
        {
          "source": "/rd-primitives.css",
          "destination": "/styles/rd.css"
        },
        {
          "source": "/rd-components.css",
          "destination": "/styles/rd.css"
        },
        {
          "source": "/design",
          "destination": "/design.html"
        },
        {
          "source": "/audit",
          "destination": "/audit.html"
        },
        {
          "source": "/reset",
          "destination": "/reset.html"
        },
        {
          "source": "/pool/policies",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/config",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/metrics",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/deployment/check",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/providers/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/jobs",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/jobs/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/assignments/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/receipts/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/audits/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/points/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/reputation/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/status",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/signaling/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/pool/peer/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/zero/gemini",
          "function": {
            "functionId": "zeroGemini",
            "region": "us-central1"
          }
        },
        {
          "source": "/zero/gemini/**",
          "function": {
            "functionId": "zeroGemini",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/**",
          "run": {
            "serviceId": "reploid-pool",
            "region": "us-central1"
          }
        },
        {
          "source": "/",
          "destination": "/index.html"
        },
        {
          "source": "/ask",
          "destination": "/index.html"
        },
        {
          "source": "/compute",
          "destination": "/index.html"
        },
        {
          "source": "/records",
          "destination": "/index.html"
        },
        {
          "source": "/history",
          "destination": "/index.html"
        },
        {
          "source": "/network",
          "destination": "/index.html"
        },
        {
          "source": "/zero",
          "destination": "/index.html"
        },
        {
          "source": "/x",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
