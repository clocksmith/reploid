{
  "schema": "reploid.pool.config/v1",
  "configVersion": "2026-06-07.lane-a-protocol.v1",
  "claim": "receipt-backed, audit-backed, reputation-backed, policy-controlled browser inference",
  "forbiddenClaims": [
    "trustless",
    "hardware-attested",
    "guaranteed honest GPU execution",
    "proof of honest browser execution",
    "decentralized AI compute marketplace at launch"
  ],
  "trustTiers": {
    "T1_signed_receipt": {
      "label": "Signed receipt",
      "evidenceRequirements": [
        "assignment",
        "providerSignature",
        "inputHash",
        "generationConfigHash",
        "outputHash",
        "tokenIdsHash"
      ],
      "claim": "One provider identity signed an assignment-bound receipt."
    },
    "T2_canary_audited": {
      "label": "Canary audited",
      "evidenceRequirements": [
        "T1_signed_receipt",
        "recentPassedCanary"
      ],
      "claim": "Provider has recent hidden deterministic audit evidence."
    },
    "T3_redundant_agreement": {
      "label": "Redundant agreement",
      "evidenceRequirements": [
        "T1_signed_receipt",
        "matchingOutputHash",
        "matchingTokenIdsHash",
        "multipleProviders"
      ],
      "claim": "Independent browser providers produced matching deterministic receipt hashes."
    },
    "T1_ring_baseline": {
      "label": "Ring baseline",
      "evidenceRequirements": [
        "T1_signed_receipt",
        "ringCommitment"
      ],
      "claim": "One ring member produced a signed receipt with ring metadata."
    },
    "T2_paired_ring_receipt": {
      "label": "Paired ring receipt",
      "evidenceRequirements": [
        "ringCommitment",
        "twoProviders",
        "matchingOutputHash",
        "matchingTokenIdsHash"
      ],
      "claim": "Two browser ring members agreed on deterministic output and token hashes."
    },
    "T3_majority_ring_receipt": {
      "label": "Majority ring receipt",
      "evidenceRequirements": [
        "ringCommitment",
        "majorityProviders",
        "matchingOutputHash",
        "matchingTokenIdsHash"
      ],
      "claim": "A majority browser ring agreed on deterministic output and token hashes."
    },
    "T4_max_ring_quorum_receipt": {
      "label": "Max ring quorum receipt",
      "evidenceRequirements": [
        "ringCommitment",
        "threeOfFourProviders",
        "matchingOutputHash",
        "matchingTokenIdsHash"
      ],
      "claim": "Three of four browser ring members agreed on deterministic output and token hashes."
    },
    "T4_requester_accepted": {
      "label": "Requester accepted",
      "evidenceRequirements": [
        "verifierAccepted",
        "requesterSignature",
        "agreementHash",
        "ledgerEffect"
      ],
      "claim": "Requester countersigned the verifier-accepted agreement and spend."
    }
  },
