{
  "projectId": "reploid",
  "region": "us-central1",
  "serviceName": "reploid-pool",
  "artifactRepository": "reploid",
  "imageName": "reploid-pool",
  "runtimeEnv": {
    "NODE_ENV": "production",
    "PORT": "8080",
    "POOL_BACKEND_ONLY": "true",
    "POOL_STORE": "firestore",
    "POOL_VERIFY_FIREBASE_AUTH": "true",
    "POOL_REQUIRE_FIREBASE_AUTH": "true",
    "POOL_JSON_LIMIT": "512kb",
    "POOL_SIGNAL_SESSION_TTL_MS": "600000",
    "POOL_MAX_SIGNAL_PAYLOAD_BYTES": "65536",
    "POOL_MAX_SIGNAL_MESSAGES_PER_POLL": "100",
    "REPLOID_POOL_MODEL_BASE_URL": "<required-offloaded-model-artifact-base-url>",
    "REPLOID_DOPPLER_MODULE_URL": "<required-reviewed-doppler-browser-module-url>"
  },
  "browserEnv": {
    "REPLOID_POOL_MODEL_BASE_URL": "<required-offloaded-model-artifact-base-url>",
    "REPLOID_DOPPLER_MODULE_URL": "<required-reviewed-doppler-browser-module-url>"
  },
  "readiness": {
    "endpoint": "/pool/deployment/check",
    "requiresOk": true
  }
}
