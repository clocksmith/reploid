{
  "levels": {
    "tabula": {
      "name": "TABULA",
      "description": "Bootstrap substrate core - 7 foundational modules",
      "modules": [
        "DIContainer",
        "ErrorStore",
        "EventBus",
        "StateHelpersPure",
        "StateManager",
        "Utils",
        "VFS"
      ]
    },
    "capsule": {
      "name": "CAPSULE",
      "description": "Reploid core - 11 additional modules",
      "extends": "tabula",
      "modules": [
        "AgentLoop",
        "CircuitBreaker",
        "ContextManager",
        "ProviderRegistry",
        "LLMClient",
        "PersonaManager",
        "ResponseParser",
        "SchemaRegistry",
        "ToolExecutor",
        "ToolRunner",
        "ToolWriter"
      ]
    },
    "spark": {
      "name": "ZERO",
      "description": "Capsule + extended local brain/runtime support - 2 additional modules",
      "extends": "capsule",
      "modules": [
        "DopplerToolbox",
        "TelemetryTimeline"
      ]
    },
    "reflection": {
      "name": "REFLECTION",
      "description": "Zero + self-awareness - 6 additional modules",
      "extends": "spark",
      "modules": [
        "HITLController",
        "RateLimiter",
        "ReflectionAnalyzer",
        "ReflectionStore",
        "StreamParser",
        "VerificationManager"
      ]
    },
    "cognition": {
      "name": "COGNITION",
      "description": "Reflection + memory and reasoning - 11 additional modules",
      "extends": "reflection",
      "modules": [
        "CognitionAPI",
        "EmbeddingStore",
        "GEPAOptimizer",
        "KnowledgeGraph",
        "KnowledgeTree",
        "MemoryManager",
        "PromptMemory",
        "RuleEngine",
        "SemanticMemory",
        "SymbolGrounder",
        "TransformersClient"
      ]
    },
    "substrate": {
      "name": "SUBSTRATE",
      "description": "Cognition + runtime infrastructure - 13 additional modules",
      "extends": "cognition",
      "modules": [
        "AuditLogger",
        "BrowserAPIs",
        "GenesisSnapshot",
        "IntentBundleGate",
        "Observability",
        "PerformanceMonitor",
        "PolicyEngine",
        "ReplayEngine",
        "SchemaValidator",
        "SubstrateLoader",
        "TraceStore",
        "VFSSandbox",
        "WorkerManager"
      ]
    },
    "full": {
      "name": "FULL",
      "description": "Substrate + advanced multi-agent systems - 16 additional modules",
      "extends": "substrate",
      "modules": [
        "ArenaCompetitor",
        "ArenaHarness",
        "ArenaMetrics",
        "Consensus",
        "EpisodicMemory",
        "FederatedLearning",
        "FunctionGemmaOrchestrator",
        "HybridRetrieval",
        "MultiModelCoordinator",
        "MultiModelEvaluator",
        "NeuralCompiler",
        "IntentBundleLoRA",
        "PromptScoreMap",
        "SwarmSync",
        "SwarmTransport",
        "WebRTCSwarm"
      ]
    }
  },
