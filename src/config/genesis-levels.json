  "defaultLevel": "spark",
  "defaultBlueprintPath": "none",
  "workerTypes": {
    "explore": {
      "name": "Explore",
      "description": "Read-only reconnaissance - safe information gathering",
      "tools": [
        "ReadFile",
        "ListFiles",
        "FileOutline",
        "Grep",
        "Find",
        "Head",
        "Tail"
      ],
      "canSpawnWorkers": false,
      "defaultModelRole": "fast"
    },
    "analyze": {
      "name": "Analyze",
      "description": "Read + draft capabilities (no persistent writes)",
      "tools": [
        "ReadFile",
        "ListFiles",
        "FileOutline",
        "Grep",
        "Find",
        "Head",
        "Tail"
      ],
      "canSpawnWorkers": false,
      "defaultModelRole": "fast"
    },
    "execute": {
      "name": "Execute",
      "description": "Full RSI capability - can modify VFS",
      "tools": "*",
      "canSpawnWorkers": false,
      "defaultModelRole": "primary"
    }
  },
  "modelRoles": {
    "orchestrator": {
      "description": "Main agent brain - strategic thinking",
      "default": null
